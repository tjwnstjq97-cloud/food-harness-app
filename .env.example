# ─────────────────────────────────────────────────────────────
# .env.example — 환경변수 설정 가이드
# ─────────────────────────────────────────────────────────────
# 사용법:
#   cp .env.example .env
#   .env 파일에 실제 값을 입력하세요.
#   .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 포함됨)
#
# EXPO_PUBLIC_ 접두사:
#   클라이언트 번들에 포함됩니다. API Key 절대 금지.
#   URL, 공개 설정값만 허용.
#
# 접두사 없는 변수:
#   Supabase Edge Function에서만 사용. 클라이언트에 노출 금지.
# ─────────────────────────────────────────────────────────────

# ─── Supabase (클라이언트 공개 가능 값) ──────────────────────
# 1. https://supabase.com 에서 프로젝트 생성
# 2. Settings > API 에서 복사
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── 앱 기본 설정 ────────────────────────────────────────────
# 기본 지역 설정 (KR 또는 GLOBAL)
EXPO_PUBLIC_APP_REGION=KR

# 디버그 모드 (true면 추가 로그 활성화 — 프로덕션에서는 false)
EXPO_PUBLIC_DEBUG=false

# ─── 네이버 지도/검색 API (KR용) ─────────────────────────────
# 등록 경로: https://developers.naver.com/apps/#/register
# Application 등록 → 검색API 체크 → Client ID, Secret 복사
# 중요: Edge Function 환경변수에 등록. 클라이언트에 절대 노출 금지.
NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id
NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret

# 네이버 지도 SDK (KR 지도 탭용)
# 등록 경로: https://console.ncloud.com → AI·NAVER API → Maps
NAVER_MAP_CLIENT_ID=your_naver_map_client_id

# ─── 구글 Places API (GLOBAL용) ──────────────────────────────
# 등록 경로: https://console.cloud.google.com → API & Services → Credentials
# Places API (New) 활성화 필요
# 중요: Edge Function 환경변수에 등록. 클라이언트에 절대 노출 금지.
GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── Supabase Edge Function (로컬 개발용) ───────────────────
# supabase start 실행 후 로컬 URL
# 프로덕션에서는 자동으로 https://your-project.supabase.co/functions/v1 사용
# SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1

# ─── Supabase Service Role Key (서버 전용) ───────────────────
# 중요: 절대 클라이언트에 노출 금지! Edge Function 서버 환경에서만 사용.
# Supabase Dashboard → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
